programa {
  funcao inicio() {
    inteiro a,b
    escreva("digite o primeiro valor ")
    leia(a)
    escreva("Digite o segundo valor: ")
    leia(b)
    escreva ("---Comparação---")
    escreva(" a > b = ",(a>b),"\n")
    escreva(" a >= b = ",(a>=b),"\n")
    escreva(" a < b = ",(a<b),"\n")
    escreva(" a <= b = ",(a<=b),"\n")
    escreva(" a != b = ",(a!=b),"\n")
    escreva(" a == b = ",(a==b+3),"\n")
    escreva(" a <= b = ",(a<=b-2),"\n")
  }
}

